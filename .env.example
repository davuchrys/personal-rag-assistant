# Copy this file to .env and fill in the values before running docker compose.

# ── LLM backend — pick ONE of the two options ────────────────────────────────
# Option 1 (default): OpenRouter cloud API. Get a key at https://openrouter.ai
USE_OLLAMA=false
OPENROUTER_API_KEY=

# Option 2: local Ollama on the HOST machine (model "llama3" must be pulled).
# Set USE_OLLAMA=true; the container reaches it via host.docker.internal
# automatically — no URL change needed.
# USE_OLLAMA=true

# ── Multi-user accounts (Supabase) ───────────────────────────────────────────
# Without these the app still runs, but sign-up/login is disabled.
SUPABASE_URL=
SUPABASE_KEY=

# ── Optional / advanced (off by default) ─────────────────────────────────────
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# ENABLE_RERANKER=false
